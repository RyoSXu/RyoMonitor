# 复制到 /etc/ryo-monitor.env 并替换密钥。安装脚本会用 `bin/ryo-monitor genenv <密码>` 自动生成。
MON_AUTH_HOST=127.0.0.1
MON_AUTH_PORT=8090
MON_AUTH_WEB_ROOT=/opt/ryo-monitor/app
MON_AUTH_SESSION_TTL=604800
MON_AUTH_PASSWORD_HASH=pbkdf2_sha256$260000$replace_with_salt$replace_with_hash
MON_AUTH_SECRET=replace_with_random_secret

# 置 1 时信任前置反代/SSO 已完成鉴权；构建时 scripts/build.sh 会自动加 -tags trustproxy 裁掉内置登录。
# MON_AUTH_TRUST_PROXY=1

# 采集器配置
RYO_MONITOR_IFACE=eth0
# 服务监控：每项 "显示名=单元"，空格分隔（显示名不能含空格）。
# systemd 单元直接写单元名；docker 容器用前缀 docker:<容器名>。
RYO_MONITOR_SERVICES="OpenList=openlist Caddy=caddy SSH=ssh RyoAuthGate=auth-gate ConvertX=docker:convertx"
